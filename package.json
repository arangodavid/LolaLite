{
  "name": "lola-lite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint . && node -e \"console.log('Biome lint passed')\"",
    "lint:fix": "biome lint --write . && node -e \"console.log('Biome lint fix completed')\"",
    "format": "biome format --write . && node -e \"console.log('Biome format completed')\"",
    "format:check": "biome check . --linter-enabled=false --assist-enabled=false && node -e \"console.log('Biome format check passed')\""
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
